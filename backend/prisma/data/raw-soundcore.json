 motion+’s built-in 6, 700 mAh battery lets you effortlessly soundtrack wild weekends, cozy evenings, or long summer days outdoors.\\u003c\\/li\\u003e\\n  \\u003cli\\u003eMotion Plus speakers bought after November 2022 do not suppport TWS pairing with Motion Plus speakers purchased prior to November 2022.\\u003c\\/li\\u003e\\n\\u003c\\/ul\\u003e\\n\\u003cstyle\\u003e\\u003c!--\\na#amazon {display: none;}\\n--\\u003e\\u003c\\/style\\u003e\\n\\u003cstyle\\u003e\\u003c!--\\na#amazon_cta {display: none;}\\n--\\u003e\\u003c\\/style\\u003e\",\"published_at\":\"2026-03-12T02:53:49-07:00\",\"created_at\":\"2024-07-25T02:17:34-07:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\",\"vendor\":\"soundcoreusa\",\"product_type\":\"speaker\",\"tags\":[\"kelong\"],\"variants\":[{\"id\":44448743751870,\"title\":\"Black\",\"option1\":\"Black\",\"option2\":null,\"option3\":null,\"sku\":\"A3116011-F0\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":30987029577918,\"product_id\":8268139790526,\"position\":1,\"created_at\":\"2022-04-15T02:33:59-07:00\",\"updated_at\":\"2025-07-03T03:32:46-07:00\",\"alt\":null,\"width\":1200,\"height\":1200,\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/5_237d67dc-cc7b-4772-afff-ee5f27c6c76b.jpg?v=1751538766\",\"variant_ids\":[44448743751870]},\"available\":false,\"price\":\"69.99\",\"grams\":1311,\"compare_at_price\":null,\"position\":1,\"product_id\":8268139790526,\"created_at\":\"2024-07-25T02:17:35-07:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\"}],\"images\":[{\"id\":30987029577918,\"created_at\":\"2022-04-15T02:33:59-07:00\",\"position\":1,\"updated_at\":\"2025-07-03T03:32:46-07:00\",\"product_id\":8268139790526,\"variant_ids\":[44448743751870],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/5_237d67dc-cc7b-4772-afff-ee5f27c6c76b.jpg?v=1751538766\",\"width\":1200,\"height\":1200},{\"id\":34983793524926,\"created_at\":\"2024-04-08T01:55:25-07:0