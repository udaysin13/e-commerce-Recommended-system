a-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong\\u003eFully-Waterproof:\\u003c\\/strong\\u003e Even full submersion in water won’t stop Trance Go outdoor Bluetooth speaker thanks to its IPX7 waterproof casing.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003cli data-mce-fragment=\\\"1\\\"\\u003e\\u003cspan class=\\\"a-list-item\\\" data-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong\\u003e24-Hour Playtime:\\u003c\\/strong\\u003e Keep the music playing throughout multiple events thanks to Trance Go outdoor Bluetooth speaker’s powerful battery. A built-in USB port allows you to conveniently charge other devices while in use.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003c\\/ul\\u003e\",\"published_at\":\"2026-03-12T02:55:56-07:00\",\"created_at\":\"2021-05-09T19:49:53-07:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\",\"vendor\":\"soundcoreusa\",\"product_type\":\"speaker\",\"tags\":[\"kelong\",\"Trance Series\"],\"variants\":[{\"id\":41099053400254,\"title\":\"Black\",\"option1\":\"Black\",\"option2\":null,\"option3\":null,\"sku\":\"A3396011\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":28553100067006,\"product_id\":6693539643582,\"position\":1,\"created_at\":\"2021-05-09T19:49:55-07:00\",\"updated_at\":\"2021-05-09T19:49:55-07:00\",\"alt\":\"soundcore portable speaker with sturdy handle\",\"width\":1500,\"height\":1500,\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/1.jpg?v=1620614995\",\"variant_ids\":[41099053400254]},\"available\":false,\"price\":\"109.99\",\"grams\":3100,\"compare_at_price\":null,\"position\":1,\"product_id\":6693539643582,\"created_at\":\"2022-01-13T04:02:37-08:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\"}],\"images\":[{\"id\":28553100067006,\"created_at\":\"2021-05-09T19:49:55-07:00\",\"position\":1,\"updated_at\":\"2021-05-09T19:49:55-07:00\",\"product_id\":6693539643582,\"variant_ids\":[41099053400254],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/68