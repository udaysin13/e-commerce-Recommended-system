761\\/6830\\/files\\/A3872Z11.png?v=1749639360\",\"width\":1600,\"height\":1600},{\"id\":34290579112126,\"created_at\":\"2023-11-23T00:09:10-08:00\",\"position\":2,\"updated_at\":\"2025-06-11T03:56:00-07:00\",\"product_id\":8499205013694,\"variant_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/files\\/A3872Z11_TD02_V1_defec5b3-7068-4bf2-93ff-cca825175c46.jpg?v=1749639360\",\"width\":3001,\"height\":3001},{\"id\":34187347591358,\"created_at\":\"2023-10-30T00:33:21-07:00\",\"position\":3,\"updated_at\":\"2025-06-11T03:56:00-07:00\",\"product_id\":8499205013694,\"variant_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/A3872Z11_TD03_V1.jpg?v=1749639360\",\"width\":3001,\"height\":3001},{\"id\":34187347624126,\"created_at\":\"2023-10-30T00:33:21-07:00\",\"position\":4,\"updated_at\":\"2025-06-11T03:56:00-07:00\",\"product_id\":8499205013694,\"variant_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/A3872Z11_TD04_V1.jpg?v=1749639360\",\"width\":3001,\"height\":3001},{\"id\":34187347656894,\"created_at\":\"2023-10-30T00:33:21-07:00\",\"position\":5,\"updated_at\":\"2025-06-11T03:56:00-07:00\",\"product_id\":8499205013694,\"variant_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/A3872Z11_TD05_V1.jpg?v=1749639360\",\"width\":3001,\"height\":3001},{\"id\":34187347689662,\"created_at\":\"2023-10-30T00:33:21-07:00\",\"position\":6,\"updated_at\":\"2025-06-11T03:56:00-07:00\",\"product_id\":8499205013694,\"variant_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/A3872Z11_TD06_V1.jpg?v=1749639360\",\"width\":3001,\"height\":3001}],\"options\":[{\"name\":\"Color\",\"position\":1,\"values\":[\"Midnight Black\"]}]},{\"id\":8597328363710,\"title\":\"AeroFit 2 (Point of Sale)\",\"handle\":\"aerofit-2-point-of-sale\",\"body_html\":\"\\u003cdiv data-page-id=\\\"O4xbdPwFhoEchNxNmMbckOnTnof\\\" data-lark-html-role=\\\"root\\\" data-docx-has-block-data=\\\"false\\\"\\u003e\\n\\u003cdiv class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\n\\u003cmeta charset=\\\"utf-8\\\"\\u003e\\n\\u003cdiv data-docx-has-block-data=\\\"false\\\" data-lark-html-role=\\\"root\\\" data-page-id=\\\"O4xbdPwFhoEchNxNmMbckOnTnof\\\"\\u003e\\n\\u003cul\\u003e\\n\\u003cli class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\n\\u003cstrong\\u003e\\u003cspan\\u003eStay Aware, Stay Comfortable：\\u003c\\/span\\u003e\\u003c\\/strong\\u003eAeroFit 2 open-ear headphones offer all-day comfort with soft materials and a non-invasive, double-curved design, keeping you attuned to the world while enjoying music.\\u003c\\/li\\u003e\\n\\u003cli class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\n\\u003cmeta charset=\\\"utf-8\\\"\\u003e\\n\\u003cstrong\\u003eA Perfect Fit for Every Ear：\\u003c\\/strong\\u003esoundcore's innovative 4-level adjustable ear hooks ensure a comfortable fit tailored to over 99% of ear shapes and sizes.\\u003c\\/li\\u003e\\n\\u003cli class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\n\\u003cmeta charset=\\\"utf-8\\\"\\u003e\\n\\u003cspan\\u003e\\u003cstrong\\u003eClose to the Ear Canal for Deeper Bass\\u003c\\/strong\\u003e: Adjustable ear hooks bring the sound closer, delivering the bass you crave. With a maximum boost of 7.5dB over non-adjustable hooks, enjoy richer, more powerful bass.\\u003c\\/span\\u003e\\n\\u003c\\/li\\u003e\\n\\u003cli class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\u003cspan\\u003e\\u003cmeta charset=\\\"utf-8\\\"\\u003e\\n\\u003cstrong\\u003eFree Al Translation: \\u003c\\/strong\\u003eSupports more than 100 languages, real-time response, and high accuracy. From tropical vacations to global conferences, stay in the loop wherever life takes you. Note: Ensure the soundcore app is version 3.8.7 or later and the earbud firmware is updated to the latest version.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003cli class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\n\\u003cmeta charset=\\\"utf-8\\\"\\u003e\\n\\u003cstrong\\u003eRich Sound: \\u003c\\/strong\\u003eDeep bass, clear mids, and vivid treble, fueled by 20mm × 11.5mm racetrack drivers and BassTurbo acoustics. Indulge in full-bodied wireless Hi-Res audio, refined by LDAC.\\u003c\\/li\\u003e\\n\\u003cli class=\\\"ace-line ace-line old-record-id-UAbmdWnwRozsrQxP3xvcCQtMnld\\\"\\u003e\\n\\u003cstrong\\u003eWireless Recharge, Long Playtime: \\u003c\\/strong\\u003ePlace the case on a wireless charger for a tangle-free recharge. Get up to 10 hours of music on a single charge, extendable to 42 hours with the case.\\u003c\\/li\\u003e\\n\\u003c\\/ul\\u003e\\n\\u003c\\/div\\u003e\\n\\u003c\\/div\\u003e\\n\\u003c\\/div\\u003e\",\"published_at\":\"2026-03-12T02:53:32-07:00\",\"created_at\":\"2025-10-16T03:59:02-07:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\",\"vendor\":\"soundcoreusa\",\"product_type\":\"\",\"tags\":[\"code not applied\",\"kelong\"],\"variants\":[{\"id\":45480300806334,\"title\":\"Midnight\",\"option1\":\"Midnight\",\"option2\":null,\"option3\":null,\"sku\":\"A3874Z11\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":37632003997886,\"product_id\":8597328363710,\"position\":1,\"created_at\":\"2025-03-09T21:29:21-07:00\",\"updated_at\":\"2025-06-11T02:44:31-07:00\",\"alt\":\"soundcore open-ear black earbuds with design awards\",\"width\":1600,\"height\":1600,\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/files\\/A3874Z11_Rich_image_TD01_US_V2.png?v=1749635071\",\"variant_ids\":[45480300806334]},\"available\":true,\"price\":\"73.99\",\"grams\":215,\"compare_at_price\":\"129.99\",\"position\":1,\"product_id\":8597328363710,\"created_at\":\"2025-10-16T03:59:02-07:00\",\"updated_at\"