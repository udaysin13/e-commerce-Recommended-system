party early, and go to bed late!\\u003c\\/li\\u003e\\n\\u003cli\\u003e\\n\\u003cb\\u003e\\u003cspan class=\\\"a-list-item\\\"\\u003eWireless Stereo\\u003c\\/span\\u003e\\u003c\\/b\\u003e: Connect 2 Flare Mini outdoor Bluetooth speakers via a single bluetooth device for souped-up stereo sound. Designed to work with any device, including iPhone, iPad, iPod, Mac, Smartphones, Tablets, Laptops, Computers, Chromebooks, TV, PD.\\u003c\\/li\\u003e\\n\\u003c\\/ul\\u003e\\n\\u003cstyle\\u003e\\u003c!--\\na#amazon_cta {display: none;}\\n--\\u003e\\u003c\\/style\\u003e\",\"published_at\":\"2026-03-12T02:56:08-07:00\",\"created_at\":\"2020-12-05T01:23:58-08:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\",\"vendor\":\"soundcoreusa\",\"product_type\":\"speaker\",\"tags\":[\"Flare Series\",\"kelong\",\"Light Show\",\"Waterproof\"],\"variants\":[{\"id\":37651979108542,\"title\":\"Black\",\"option1\":\"Black\",\"option2\":null,\"option3\":null,\"sku\":\"A3167012\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":29923853697214,\"product_id\":6109030842558,\"position\":1,\"created_at\":\"2021-09-23T03:10:34-07:00\",\"updated_at\":\"2021-09-23T03:10:35-07:00\",\"alt\":\"soundcore black speaker with colorful LED ring\",\"width\":1500,\"height\":1500,\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/5_aed7ec91-fcd0-4f5c-8883-3d1bef777315.jpg?v=1632391835\",\"variant_ids\":[37651979108542]},\"available\":false,\"price\":\"42.99\",\"grams\":673,\"compare_at_price\":null,\"position\":1,\"product_id\":6109030842558,\"created_at\":\"2020-12-05T01:23:58-08:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\"}],\"images\":[{\"id\":29923853697214,\"created_at\":\"2021-09-23T03:10:34-07:00\",\"position\":1,\"updated_at\":\"2021-09-23T03:10:35-07:00\",\"product_id\":6109030842558,\"variant_ids\":[37651979108542],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/5_aed7ec91-fcd0-4f5c-8883-3d1bef777315.j