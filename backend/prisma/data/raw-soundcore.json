_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/products\\/6_402c688e-c980-4a0a-9260-a443aaac7f3a.jpg?v=1642669136\",\"width\":1500,\"height\":1500}],\"options\":[{\"name\":\"Color\",\"position\":1,\"values\":[\"Blue\"]}]},{\"id\":7141835440318,\"title\":\"Life Q35 | Noise-Cancelling Headphones with LDAC\",\"handle\":\"a3027012\",\"body_html\":\"\\u003cmeta charset=\\\"utf-8\\\"\\u003e\\n\\u003cul class=\\\"a-unordered-list a-vertical a-spacing-mini\\\" data-mce-fragment=\\\"1\\\"\\u003e\\n\\u003cli data-mce-fragment=\\\"1\\\"\\u003e\\u003cspan class=\\\"a-list-item\\\" data-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong data-mce-fragment=\\\"1\\\"\\u003eGold Standard of Sound:\\u003c\\/strong\\u003e\\u003cspan data-mce-fragment=\\\"1\\\"\\u003e \\u003c\\/span\\u003eCustom silk-diaphragm drivers accurately reproduce music across a wider frequency range and cut out distortion to deliver sound that’s both Hi-Res Audio and Hi-Res Audio Wireless certified.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003cli data-mce-fragment=\\\"1\\\"\\u003e\\u003cspan class=\\\"a-list-item\\\" data-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong data-mce-fragment=\\\"1\\\"\\u003eLDAC Technology:\\u003c\\/strong\\u003e\\u003cspan data-mce-fragment=\\\"1\\\"\\u003e \\u003c\\/span\\u003e3 times more data is transmitted to Life Q35 active noise cancelling headphones than via standard Bluetooth codecs. This lossless transfer ensures you hear every tiny detail in the music.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003cli data-mce-fragment=\\\"1\\\"\\u003e\\u003cspan class=\\\"a-list-item\\\" data-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong data-mce-fragment=\\\"1\\\"\\u003eMulti-Mode Noise Cancelling:\\u003c\\/strong\\u003e\\u003cspan data-mce-fragment=\\\"1\\\"\\u003e \\u003c\\/span\\u003e2 microphones on each earcup detect and filter out distracting noises in your vicinity. Switch between Transport, Outdoor, and Indoor modes for a tailored noise cancelling experience.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003cli data-mce-fragment=\\\"1\\\"\\u003e\\u003cspan class=\\\"a-list-item\\\" data-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong data-mce-fragment=\\\"1\\\"\\u003eComfortable and Convenient:\\u003c\\/strong\\u003e\\u003cspan data-mce-fragment=\\\"1\\\"\\u003e \\u003c\\/span\\u003eLife Q35 active noise cancelling headphones can be worn all day thanks to their lightweight build and memory foam padded earcups and headband. A built-in sensor detects when they’re removed from your ears and instantly pauses the audio.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003cli data-mce-fragment=\\\"1\\\"\\u003e\\u003cspan class=\\\"a-list-item\\\" data-mce-fragment=\\\"1\\\"\\u003e\\u003cstrong data-mce-fragment=\\\"1\\\"\\u003eAI-Enhanced Calls:\\u003c\\/strong\\u003e\\u003cspan data-mce-fragment=\\\"1\\\"\\u003e \\u003c\\/span\\u003eThe beamforming microphones on Life Q35 active noise cancelling headphones pick up your voice with incredible accuracy by using an AI algorithm that’s been tested thousands of times. Calls sound crisp, clear, and free of unwanted noise.\\u003c\\/span\\u003e\\u003c\\/li\\u003e\\n\\u003c\\/ul\\u003e\",\"published_at\":\"2026-03-12T02:55:26-07:00\",\"created_at\":\"2022-01-25T18:27:49-08:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\",\"vendor\":\"Soundcore\",\"product_type\":\"headphone\",\"tags\":[\"Active Noise Cancelling\",\"Home Office\",\"kelong\",\"Life Series\",\"Long-Lasting Playtime\",\"Premium Sound Quality\",\"soundcore_vd_sale_2024\",\"soundcore_xmas_sale_2312\",\"Travel\"],\"variants\":[{\"id\":41149233430718,\"title\":\"Black\",\"option1\":\"Black\",\"option2\":null,\"option3\":null,\"sku\":\"A3027012\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":30711811506366,\"product_id\":7141835440318,\"position\":1,\"created_at\":\"2022-01-28T01:34:44-08:00\",\"updated_at\":\"2022-01-28T01:34:47-08:00\",\"alt\":\"soundcore black headphones with Hi-Res Audio and LDAC