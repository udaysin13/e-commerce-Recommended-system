\/0516\\/3761\\/6830\\/files\\/61F-zGXATyL._AC_SX466.jpg?v=1775097776\",\"width\":466,\"height\":466},{\"id\":40725826011326,\"created_at\":\"2026-02-02T02:45:39-08:00\",\"position\":24,\"updated_at\":\"2026-04-01T19:42:56-07:00\",\"product_id\":8771129540798,\"variant_ids\":[],\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/files\\/61-Ti7RB5aL._AC_SX466.jpg?v=1775097776\",\"width\":466,\"height\":466}],\"options\":[{\"name\":\"Color\",\"position\":1,\"values\":[\"Jet Black\",\"Latte Cream\",\"Sky Blue\",\"Pink\"]}]},{\"id\":8765596369086,\"title\":\"AeroFit 2 Pro Dual-Form Earbuds with Open-Ear and Active Noise Cancellation Form\",\"handle\":\"aerofit-2-pro\",\"body_html\":\"\\u003cul\\u003e\\n\\u003cli\\u003e\\n\\u003cstrong\\u003eOne Switch, Two Forms:\\u003c\\/strong\\u003e Adjust the ear hooks to seamlessly access Open-Ear and Active Noise Cancellation forms. Whether you're using it during workouts or your commute, AeroFit 2 Pro adapts seamlessly to every part of your day.\\u003c\\/li\\u003e\\n\\u003cli\\u003e\\n\\u003cstrong\\u003eOpen-Ear Form—Comfort With Every Wear:\\u003c\\/strong\\u003e Stay comfortable all day thanks to the open-ear design that keeps your ears breathable. The skin-friendly liquid silicone ear hooks ensure a soft, pressure-free fit.\\u003c\\/li\\u003e\\n\\u003cli\\u003e\\n\\u003cstrong\\u003eActive Noise Cancellation Form—Reduce Noise for Deep Focus: \\u003c\\/strong\\u003eBe heard in noisy environments. These earbuds effectively reduce background noise so you can enjoy clear, private listening whether you're on a busy street or a noisy subway station.\\u003c\\/li\\u003e\\n\\u003cli\\u003e\\n\\u003cstrong\\u003eExperience Theater-Like Sound:\\u003c\\/strong\\u003e Immerse yourself in studio-grade sound powered by 11.8 mm composite drivers, Hi-Res audio, and LDAC technology. With dynamic head tracking, sound moves all around you—delivering a vivid, theatre-like experience.\\u003c\\/li\\u003e\\n\\u003cli\\u003e\\n\\u003cstrong\\u003eAI-Boosted Clear Calls: \\u003c\\/strong\\u003eWith 4 mics and AI-boosted call technology, your conversations come through with precision and sharpness—ensuring reliable clarity even on a busy street.\\u003c\\/li\\u003e\\n\\u003cli\\u003e\\n\\u003cstrong\\u003eWill AeroFit 2 Pro Fit Me:\\u003c\\/strong\\u003e While AeroFit 2 Pro fits roughly 90% of ears, trust our 30-day money-back guarantee and try them for yourself, rather than rely on the measurements alone.\\u003c\\/li\\u003e\\n\\u003c\\/ul\\u003e\",\"published_at\":\"2026-04-13T21:23:41-07:00\",\"created_at\":\"2026-04-13T21:23:07-07:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\",\"vendor\":\"Soundcore\",\"product_type\":\"\",\"tags\":[\"buy_main_send_gift\"],\"variants\":[{\"id\":46604441354430,\"title\":\"Matte Black\",\"option1\":\"Matte Black\",\"option2\":null,\"option3\":null,\"sku\":\"A3875Z11\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":40608793919678,\"product_id\":8765596369086,\"position\":1,\"created_at\":\"2026-01-29T19:10:00-08:00\",\"updated_at\":\"2026-01-29T19:10:19-08:00\",\"alt\":null,\"width\":1600,\"height\":1600,\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\\/0516\\/3761\\/6830\\/files\\/A3875Z11_DTC_listing_image_TD01_US_V4.png?v=1769742619\",\"variant_ids\":[46604441354430]},\"available\":true,\"price\":\"179.99\",\"grams\":328,\"compare_at_price\":null,\"position\":1,\"product_id\":8765596369086,\"created_at\":\"2026-04-13T21:23:07-07:00\",\"updated_at\":\"2026-04-17T06:35:36-07:00\"},{\"id\":46604441387198,\"title\":\"Gloss White\",\"option1\":\"Gloss White\",\"option2\":null,\"option3\":null,\"sku\":\"A3875Z21\",\"requires_shipping\":true,\"taxable\":true,\"featured_image\":{\"id\":40608793428158,\"product_id\":8765596369086,\"position\":7,\"created_at\":\"2026-01-29T19:09:59-08:00\",\"updated_at\":\"2026-01-29T19:10:36-08:00\",\"alt\":null,\"width\":1600,\"height\":1600,\"src\":\"https:\\/\\/cdn.shopify.com\\/s\\/files\\/1\