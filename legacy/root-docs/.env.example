# Seeded admin credentials used only by `npm run db:seed`
ADMIN_USERNAME=replace-with-admin-username
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Authentication / session configuration
# JWT_SECRET is used to sign user session tokens.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Optional demo user created by `npm run db:seed`
# Leave these blank to skip demo-user creation.
DEMO_USER_NAME=
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# Database configuration (PostgreSQL)
# Example:
DATABASE_URL=postgresql://user:password@localhost:5432/fluxcart?schema=public

# Optionally override Prisma shadow DB (useful for CI):
# SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/fluxcart_shadow?schema=public
