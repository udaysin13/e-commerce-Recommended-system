  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; if (Test-Path tsconfig.tsbuildinfo) { Remove-Item -Force tsconfig.tsbuildinfo }; npm.cmd run dev\"",
